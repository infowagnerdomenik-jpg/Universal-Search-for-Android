<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Theme" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/system_accent2_50</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Theme</item>
    </style>

    <style name="WindowAnimationFade" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="Theme.TransparentWallpaper" parent="Theme.Theme">
        <item name="android:windowBackground">@android:color/transparent</item>

        <item name="android:windowShowWallpaper">true</item>

        <item name="android:windowAnimationStyle">@style/WindowAnimationFade</item>

        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>